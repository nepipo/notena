# Kopiere diese Datei zu .env.local und fülle die Werte (.env.local ist gitignored).

# Supabase (öffentlich, laufen im Browser — Schutz via RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role (GEHEIM — umgeht RLS, nur Server-seitig, nie committen)
SUPABASE_SERVICE_ROLE_KEY=

# Claude API (Briefing/Coach, später)
ANTHROPIC_API_KEY=
